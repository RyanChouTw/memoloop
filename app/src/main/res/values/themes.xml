<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MemoLoop" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Word card in review screen -->
    <style name="CardWord" parent="Widget.Material3.CardView.Filled">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Base review button -->
    <style name="ButtonReview" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Neutral buttons (Again / Hard / Good) -->
    <style name="ButtonReviewNeutral" parent="ButtonReview">
        <item name="backgroundTint">@color/btn_again</item>
        <item name="android:textColor">@color/btn_neutral_text</item>
    </style>

    <style name="ButtonAgain" parent="ButtonReviewNeutral"/>
    <style name="ButtonHard" parent="ButtonReviewNeutral"/>
    <style name="ButtonGood" parent="ButtonReviewNeutral"/>

    <!-- Easy = primary green -->
    <style name="ButtonEasy" parent="ButtonReview">
        <item name="backgroundTint">@color/btn_easy</item>
        <item name="android:textColor">@color/btn_easy_text</item>
    </style>

    <!-- Tonal section card (stats, hero, etc.) -->
    <style name="CardTonal" parent="Widget.Material3.CardView.Filled">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/surface_tonal</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Dark CTA card (milestone / pro tip) -->
    <style name="CardDark" parent="Widget.Material3.CardView.Filled">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/primary</item>
    </style>
</resources>
